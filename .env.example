# Steel Valley environment variables
# Copy to .env.local (never .env — that one's git-ignored aggressively)
# Values here are PLACEHOLDERS — fill them in locally.

# ── Airtable (legacy — removed after migration in Plan 4) ──
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ── Supabase (Plan 2 — Postgres + Storage) ──
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

# ── Payload CMS (Plan 2) ──
PAYLOAD_SECRET=
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ── Resend (Plan 4 — transactional email) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_SALES_EMAIL=

# ── OpenPanel (Plan 4 — analytics, consent-gated) ──
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=

# ── WhatsApp (Plan 4 — floating CTA) ──
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Telegram (this session's autonomous-loop channel) ──
# Set after the user pings the bot once; the value below is captured automatically.
TELEGRAM_USER_CHAT_ID=
